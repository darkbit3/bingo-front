# Environment Variables
# Copy this file to .env.local and update values as needed

# API Configuration
REACT_APP_API_URL=http://localhost:3000
REACT_APP_API_KEY=your-api-key-here

# WebSocket Configuration
REACT_APP_WS_URL=ws://localhost:3000

# Game Configuration
REACT_APP_GAME_ROOM_ID=default
REACT_APP_MAX_PLAYERS=50

# Development Settings
REACT_APP_DEBUG=true
REACT_APP_LOG_LEVEL=info

# Security Configuration
REACT_APP_JWT_SECRET=your-jwt-secret-key-here
REACT_APP_JWT_EXPIRES_IN=24h

# External Services
REACT_APP_SENTRY_DSN=your-sentry-dsn-here
REACT_APP_ANALYTICS_ID=your-analytics-id-here
